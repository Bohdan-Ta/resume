# EmailJS credentials (https://dashboard.emailjs.com/)
# Public-side keys — exposed in the client bundle by design.
# Set these in Netlify UI for production, in .env.local for local dev.

VITE_EMAILJS_SERVICE_ID=service_xxxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxx
